---
import TimelinePost from "../../components/TimelinePost.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts, postsByValue, slugify, tagColor, uniqueValues } from "../../lib/posts";

export function getStaticPaths() {
  const posts = getPosts();
  return uniqueValues(posts, "categories").map((category) => ({
    params: { category },
    props: { category, posts, categories: uniqueValues(posts, "categories") }
  }));
}

const { category, posts, categories } = Astro.props;
const categoryPosts = postsByValue(posts, "categories", category).sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title={`Categories: ${category}`} type="categories">
  <div id="archives">
    <div class="categories-tags">
      {categories.map((item, index) => (
        <span>
          <a href={`/categories/${slugify(item)}/`} style={`background: ${item === category ? "linear-gradient(120deg, #9abbf7 0%, #ffbbf4 100%)" : tagColor(index)}`}>
            <span class="icon"><i class="fa-solid fa-bookmark fa-fw"></i></span>
            {item}
          </a>
        </span>
      ))}
    </div>
    {categoryPosts.map((post) => <TimelinePost post={post} />)}
  </div>
</BaseLayout>
