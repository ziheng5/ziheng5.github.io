<main class="content">
  <%
    const rawFriends = (site.data && site.data.friends) ? site.data.friends : (theme.my_friends || {})
    const friends = Array.isArray(rawFriends)
      ? rawFriends.map((friend) => [friend.name || friend.title || friend.url || "Friend", friend])
      : Object.entries(rawFriends)
  %>
  <div class="friends-container">
    <% friends.forEach(([key, value]) => { %>
      <% if (!value || !value.url) { return } %>
      <a href="<%= url_for(value.url) %>" class="friend-card" target="_blank" rel="noopener">
        <div class="friend-avatar">
          <img src="<%= url_for(value.avatar || '') %>" alt="<%= key %>">
        </div>
        <div class="friend-info">
          <h3><%= key %></h3>
          <p><%= value.desc %></p>
        </div>
      </a>
    <% }) %>
  </div>

</main>
