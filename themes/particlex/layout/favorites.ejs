<div id="archives" class="favorites-page">
    <%
        const rawFavorites = (site.data && site.data.favorites) ? site.data.favorites : (theme.favorites || []);
        const normalizeGroups = (raw) => {
            if (!raw) return [];
            const groups = Array.isArray(raw)
                ? raw.map((group) => ({
                    name: group.name || group.category || group.title || "Favorites",
                    items: group.items || group.links || group.favorites || []
                }))
                : Object.entries(raw).map(([name, group]) => ({
                    name,
                    items: Array.isArray(group) ? group : (group.items || group.links || group.favorites || [])
                }));
            return groups.filter((group) => group.items && group.items.length);
        };
        const favoriteGroups = normalizeGroups(rawFavorites);
        const slugify = (name, index) => String(name || `group-${index}`)
            .trim()
            .replace(/\s+/g, "-")
            .replace(/[^\w\u4e00-\u9fa5-]/g, "");
        const getHost = (url) => {
            try {
                return new URL(url).hostname.replace(/^www\./, "");
            } catch (error) {
                return url || "";
            }
        };
    %>

    <% if (favoriteGroups.length !== 0) { %>
    <div class="categories-tags">
        <% let prev; %>
        <% favoriteGroups.forEach((group, index) => { %>
        <%
            const colors = theme.colors.filter((color) => color !== prev);
            let id = Math.floor(Math.random() * colors.length);
            prev = colors[id];
        %>
        <span>
            <a href="#favorite-<%- slugify(group.name, index) %>" style="background: <%- colors[id] %>">
                <span class="icon">
                    <i class="fa-solid fa-star fa-fw"></i>
                </span>
                <%= group.name %>
            </a>
        </span>
        <% }); %>
    </div>

    <% favoriteGroups.forEach((group, groupIndex) => { %>
    <div class="timeline" id="favorite-<%- slugify(group.name, groupIndex) %>">
        <div class="timeline-tail"></div>
        <div class="timeline-content">
            <h3><%= group.name %></h3>
            <div class="favorite-list">
                <% group.items.forEach((item) => { %>
                <% if (!item || !item.url) { return; } %>
                <a class="favorite-item" href="<%- url_for(item.url) %>" target="_blank" rel="noopener">
                    <span class="favorite-icon">
                        <i class="fa-solid fa-<%- item.icon || "star" %> fa-fw"></i>
                    </span>
                    <span class="favorite-body">
                        <strong><%= item.name || item.title || item.url %></strong>
                        <% if (item.desc || item.description) { %>
                        <span><%= item.desc || item.description %></span>
                        <% } %>
                        <small><%- getHost(item.url) %></small>
                    </span>
                </a>
                <% }); %>
            </div>
        </div>
    </div>
    <% }); %>
    <% } else { %>
    <div class="timeline">
        <div class="timeline-tail"></div>
        <div class="timeline-content">
            <h3>Favorites</h3>
            <p>还没有收藏网页。可以在 <code>source/_data/favorites.yml</code> 中按分类添加链接。</p>
        </div>
    </div>
    <% } %>
</div>
